# Backend API base URL (must include /api/v1 path segment; see apiClient.ts).
#
# Local: copy this file to `.env.local` and adjust if your API port differs.
#
# Vercel (and any public deploy): set NEXT_PUBLIC_API_BASE_URL in the project
# Environment Variables to your deployed API HTTPS URL, e.g.
#   https://api.example.com/api/v1
# Do not leave it unset or use localhost in production — the browser may prompt
# users for "local network" / "apps on device" access when a public site calls loopback.

NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1

# Platform brand label shown in login, headers, metadata, and printed reports.
NEXT_PUBLIC_PLATFORM_NAME=CrickiERP
